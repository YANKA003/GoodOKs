<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#000000"
    tools:context=".ui.calls.CallActivity">

    <!-- Remote Video (full screen) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/surfaceRemote"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>

    <!-- Local Video (small) -->
    <org.webrtc.SurfaceViewRenderer
        android:id="@+id/surfaceLocal"
        android:layout_width="120dp"
        android:layout_height="160dp"
        android:layout_gravity="top|end"
        android:layout_margin="16dp"/>

    <!-- Call Info -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:gravity="center"
        android:layout_gravity="top"
        android:padding="24dp"
        android:background="#80000000">

        <ImageView
            android:id="@+id/ivAvatar"
            android:layout_width="80dp"
            android:layout_height="80dp"
            android:src="@drawable/bg_avatar"/>

        <TextView
            android:id="@+id/tvCallerName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="24sp"
            android:textStyle="bold"
            android:layout_marginTop="8dp"
            tools:text="John Doe"/>

        <TextView
            android:id="@+id/tvCallStatus"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="16sp"
            android:layout_marginTop="4dp"
            tools:text="@string/calling"/>

        <TextView
            android:id="@+id/tvDuration"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="#FFFFFF"
            android:textSize="14sp"
            android:visibility="gone"
            tools:text="00:00"/>

    </LinearLayout>

    <!-- Call Controls -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:gravity="center"
        android:orientation="horizontal"
        android:padding="24dp"
        android:background="#80000000">

        <!-- Mute -->
        <ImageButton
            android:id="@+id/btnMute"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_call_control"
            android:src="@android:drawable/ic_btn_speak_now"
            android:layout_marginEnd="24dp"
            android:contentDescription="@string/mute"/>

        <!-- End Call -->
        <ImageButton
            android:id="@+id/btnEndCall"
            android:layout_width="64dp"
            android:layout_height="64dp"
            android:background="@drawable/bg_call_decline"
            android:src="@android:drawable/ic_menu_close_clear_cancel"
            android:layout_marginEnd="24dp"
            android:contentDescription="@string/end_call"/>

        <!-- Speaker -->
        <ImageButton
            android:id="@+id/btnSpeaker"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_call_control"
            android:src="@android:drawable/ic_volume_big"
            android:layout_marginEnd="24dp"
            android:contentDescription="@string/speaker"/>

        <!-- Switch Camera (video calls only) -->
        <ImageButton
            android:id="@+id/btnSwitchCamera"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:background="@drawable/bg_call_control"
            android:src="@android:drawable/ic_menu_camera"
            android:visibility="gone"
            android:contentDescription="@string/switch_camera"/>

    </LinearLayout>

</FrameLayout>
