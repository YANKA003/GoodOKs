<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="4dp">

    <!-- Sent message (right aligned) -->
    <LinearLayout
        android:id="@+id/layoutSent"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="end"
        android:orientation="vertical"
        android:background="@drawable/bg_message_sent"
        android:padding="12dp"
        android:layout_marginStart="48dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tvTextSent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?android:textColorPrimary"
            android:textSize="16sp"
            tools:text="Hello!"/>

        <ImageView
            android:id="@+id/ivMediaSent"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:visibility="gone"
            tools:visibility="visible"/>

        <TextView
            android:id="@+id/tvTimeSent"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textSize="10sp"
            android:textColor="?android:textColorSecondary"
            android:layout_marginTop="4dp"
            tools:text="12:34"/>

    </LinearLayout>

    <!-- Received message (left aligned) -->
    <LinearLayout
        android:id="@+id/layoutReceived"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="start"
        android:orientation="vertical"
        android:background="@drawable/bg_message_received"
        android:padding="12dp"
        android:layout_marginEnd="48dp"
        android:visibility="gone"
        tools:visibility="visible">

        <TextView
            android:id="@+id/tvSenderName"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?attr/colorPrimary"
            android:textSize="12sp"
            android:textStyle="bold"
            android:visibility="gone"
            tools:text="John"/>

        <TextView
            android:id="@+id/tvTextReceived"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:textColor="?android:textColorPrimary"
            android:textSize="16sp"
            tools:text="Hi there!"/>

        <ImageView
            android:id="@+id/ivMediaReceived"
            android:layout_width="200dp"
            android:layout_height="200dp"
            android:scaleType="centerCrop"
            android:visibility="gone"/>

        <TextView
            android:id="@+id/tvTimeReceived"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="end"
            android:textSize="10sp"
            android:textColor="?android:textColorSecondary"
            android:layout_marginTop="4dp"
            tools:text="12:35"/>

    </LinearLayout>

</LinearLayout>
