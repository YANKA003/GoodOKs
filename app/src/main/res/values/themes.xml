<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Classic Theme (Default) -->
    <style name="Theme.GoodOK.Classic" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_classic</item>
        <item name="colorPrimaryDark">@color/primary_dark_classic</item>
        <item name="colorAccent">@color/accent_classic</item>
        <item name="android:windowBackground">@color/background_classic</item>
        <item name="android:colorBackground">@color/background_classic</item>
        <item name="android:textColorPrimary">@color/text_primary_classic</item>
        <item name="android:textColorSecondary">@color/text_secondary_classic</item>
        <item name="messageSentColor">@color/message_sent_classic</item>
        <item name="messageReceivedColor">@color/message_received_classic</item>
    </style>

    <!-- Modern Theme (Dark) -->
    <style name="Theme.GoodOK.Modern" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_modern</item>
        <item name="colorPrimaryDark">@color/primary_dark_modern</item>
        <item name="colorAccent">@color/accent_modern</item>
        <item name="android:windowBackground">@color/background_modern</item>
        <item name="android:colorBackground">@color/background_modern</item>
        <item name="android:textColorPrimary">@color/text_primary_modern</item>
        <item name="android:textColorSecondary">@color/text_secondary_modern</item>
        <item name="messageSentColor">@color/message_sent_modern</item>
        <item name="messageReceivedColor">@color/message_received_modern</item>
    </style>

    <!-- Neon Theme -->
    <style name="Theme.GoodOK.Neon" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/primary_neon</item>
        <item name="colorPrimaryDark">@color/primary_dark_neon</item>
        <item name="colorAccent">@color/accent_neon</item>
        <item name="android:windowBackground">@color/background_neon</item>
        <item name="android:colorBackground">@color/background_neon</item>
        <item name="android:textColorPrimary">@color/text_primary_neon</item>
        <item name="android:textColorSecondary">@color/text_secondary_neon</item>
        <item name="messageSentColor">@color/message_sent_neon</item>
        <item name="messageReceivedColor">@color/message_received_neon</item>
    </style>

    <!-- Childish Theme -->
    <style name="Theme.GoodOK.Childish" parent="Theme.Material3.Light.NoActionBar">
        <item name="colorPrimary">@color/primary_childish</item>
        <item name="colorPrimaryDark">@color/primary_dark_childish</item>
        <item name="colorAccent">@color/accent_childish</item>
        <item name="android:windowBackground">@color/background_childish</item>
        <item name="android:colorBackground">@color/background_childish</item>
        <item name="android:textColorPrimary">@color/text_primary_childish</item>
        <item name="android:textColorSecondary">@color/text_secondary_childish</item>
        <item name="messageSentColor">@color/message_sent_childish</item>
        <item name="messageReceivedColor">@color/message_received_childish</item>
    </style>

    <!-- Custom attrs -->
    <attr name="messageSentColor" format="color" />
    <attr name="messageReceivedColor" format="color" />

    <!-- Common styles -->
    <style name="ChatInputStyle">
        <item name="android:background">@drawable/bg_input</item>
        <item name="android:padding">12dp</item>
        <item name="android:textSize">16sp</item>
    </style>

    <style name="SendButtonStyle">
        <item name="android:background">@drawable/bg_send_button</item>
        <item name="android:padding">12dp</item>
    </style>

    <style name="AvatarStyle">
        <item name="cornerRadius">24dp</item>
    </style>

</resources>
